{
  "enabled": true,
  "name": "自动推送 Git",
  "description": "每次代理执行完成后，提醒 AI 提交并推送改动到 Git，commit message 需描述具体修改内容",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "askAgent",
    "prompt": "请检查是否有文件改动（git status），如果有改动，用 git add -A && git commit -m '具体描述本次修改内容' && git push origin main 提交并推送。commit message 要用中文简要描述本次修改了什么。如果没有改动则跳过。"
  }
}